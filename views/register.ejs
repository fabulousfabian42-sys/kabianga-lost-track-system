<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <a href="/" class="logo">
      <img src="/images/logo.svg" alt="UoK Logo">
      <div>
        <div class="title">UoK Lost & Found</div>
        <div class="subtitle">Security Office</div>
      </div>
    </a>
    <div class="user-info">
      <a href="/" class="btn">Login</a>
    </div>
  </header>
  <main>
    <div class="form-container">
      <h2>University Registration</h2>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form action="/register" method="post">
        <div class="form-group">
          <label for="name">Full Name</label>
          <input type="text" id="name" name="name" required placeholder="Your full name">
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required placeholder="student@kabianga.edu or staff@kabianga.edu">
        </div>
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" required placeholder="Choose a username">
        </div>
        <div class="form-group">
          <label for="role">Role</label>
          <select id="role" name="role" required>
            <option value="user">Student</option>
            <option value="staff">Staff</option>
          </select>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required placeholder="Choose a secure password">
        </div>
        <button type="submit" class="btn-primary">Create Account</button>
      </form>
      <p style="text-align: center; margin-top: 1rem;">Already registered? <a href="/">Login now</a>.</p>
    </div>
  </main>
</body>
</html>
