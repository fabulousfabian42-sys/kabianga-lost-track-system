<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .admin-dashboard {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
    }

    .admin-header {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.2);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
    }

    .admin-header .logo-section {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .admin-header .logo-section img {
      height: 40px;
    }

    .admin-header .title-section h1 {
      margin: 0;
      font-size: 1.5rem;
      color: #1f4d8d;
    }

    .admin-header .title-section p {
      margin: 0;
      font-size: 0.9rem;
      color: #666;
    }

    .admin-nav {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .admin-nav .user-info {
      background: #1f4d8d;
      color: white;
      padding: 0.5rem 1rem;
      border-radius: 20px;
      font-size: 0.9rem;
    }

    .admin-nav .nav-links {
      display: flex;
      gap: 0.5rem;
    }

    .admin-nav .nav-links a {
      padding: 0.5rem 1rem;
      background: #f8f9fa;
      color: #1f4d8d;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 500;
      transition: all 0.3s;
    }

    .admin-nav .nav-links a:hover {
      background: #1f4d8d;
      color: white;
    }

    .admin-main {
      padding: 2rem;
      max-width: 1400px;
      margin: 0 auto;
    }

    .welcome-section {
      background: white;
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 2rem;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    }

    .welcome-section h2 {
      margin: 0 0 0.5rem 0;
      color: #1f4d8d;
      font-size: 2rem;
    }

    .welcome-section p {
      margin: 0;
      color: #666;
      font-size: 1.1rem;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .stat-card {
      background: white;
      border-radius: 12px;
      padding: 2rem;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      border-left: 4px solid #1f4d8d;
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .stat-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
    }

    .stat-card .icon {
      width: 50px;
      height: 50px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 1rem;
    }

    .stat-card.users .icon { background: linear-gradient(135deg, #667eea, #764ba2); color: white; }
    .stat-card.items .icon { background: linear-gradient(135deg, #f093fb, #f5576c); color: white; }
    .stat-card.claims .icon { background: linear-gradient(135deg, #4facfe, #00f2fe); color: white; }
    .stat-card.found .icon { background: linear-gradient(135deg, #43e97b, #38f9d7); color: white; }
    .stat-card.lost .icon { background: linear-gradient(135deg, #fa709a, #fee140); color: white; }

    .stat-card h3 {
      margin: 0 0 0.5rem 0;
      color: #333;
      font-size: 1.1rem;
    }

    .stat-card .number {
      font-size: 2.5rem;
      font-weight: bold;
      color: #1f4d8d;
      margin: 0;
    }

    .dashboard-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 2rem;
      margin-bottom: 2rem;
    }

    .recent-activity {
      background: white;
      border-radius: 12px;
      padding: 2rem;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    }

    .recent-activity h3 {
      margin: 0 0 1.5rem 0;
      color: #1f4d8d;
      font-size: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .activity-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .activity-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem;
      background: #f8f9fa;
      border-radius: 8px;
      border-left: 3px solid #1f4d8d;
    }

    .activity-item .activity-icon {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
    }

    .activity-item .activity-icon.report { background: #10b981; color: white; }
    .activity-item .activity-icon.claim { background: #f59e0b; color: white; }

    .activity-item .activity-content {
      flex: 1;
    }

    .activity-item .activity-content .title {
      font-weight: 600;
      color: #333;
      margin: 0;
    }

    .activity-item .activity-content .meta {
      font-size: 0.9rem;
      color: #666;
      margin: 0.25rem 0 0 0;
    }

    .quick-actions {
      background: white;
      border-radius: 12px;
      padding: 2rem;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    }

    .quick-actions h3 {
      margin: 0 0 1.5rem 0;
      color: #1f4d8d;
      font-size: 1.5rem;
    }

    .action-buttons {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .action-btn {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem;
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      text-decoration: none;
      border-radius: 8px;
      transition: transform 0.3s, box-shadow 0.3s;
      font-weight: 500;
    }

    .action-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
      color: white;
    }

    .action-btn .icon {
      font-size: 1.5rem;
    }

    .data-tables {
      background: white;
      border-radius: 12px;
      padding: 2rem;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      grid-column: 1 / -1;
    }

    .data-tables h3 {
      margin: 0 0 1.5rem 0;
      color: #1f4d8d;
      font-size: 1.5rem;
    }

    .table-container {
      overflow-x: auto;
      margin-bottom: 2rem;
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
    }

    .data-table th {
      background: #f8f9fa;
      padding: 1rem;
      text-align: left;
      font-weight: 600;
      color: #1f4d8d;
      border-bottom: 2px solid #e9ecef;
    }

    .data-table td {
      padding: 1rem;
      border-bottom: 1px solid #e9ecef;
      color: #555;
    }

    .data-table tr:hover {
      background: #f8f9fa;
    }

    .status-badge {
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 500;
      text-transform: capitalize;
    }

    .status-badge.with_security { background: #dbeafe; color: #1e40af; }
    .status-badge.reported_lost { background: #fee2e2; color: #dc2626; }
    .status-badge.ready_for_claim { background: #d1fae5; color: #059669; }
    .status-badge.claimed { background: #e0e7ff; color: #5b21b6; }
    .status-badge.pending { background: #fef3c7; color: #d97706; }
    .status-badge.approved { background: #d1fae5; color: #059669; }
    .status-badge.rejected { background: #fee2e2; color: #dc2626; }

    @media (max-width: 768px) {
      .admin-header {
        flex-direction: column;
        gap: 1rem;
        text-align: center;
      }

      .admin-nav {
        flex-direction: column;
        gap: 1rem;
      }

      .admin-nav .nav-links {
        flex-wrap: wrap;
        justify-content: center;
      }

      .dashboard-grid {
        grid-template-columns: 1fr;
      }

      .stats-grid {
        grid-template-columns: 1fr;
      }

      .admin-main {
        padding: 1rem;
      }
    }
  </style>
</head>
<body class="admin-dashboard">
  <header class="admin-header">
    <div class="logo-section">
      <img src="/images/logo.svg" alt="UoK Logo">
      <div class="title-section">
        <h1>Admin Dashboard</h1>
        <p>System Management & Analytics</p>
      </div>
    </div>
    <nav class="admin-nav">
      <div class="user-info">
        <span><%= currentUser.name %> | ADMIN</span>
      </div>
      <div class="nav-links">
        <a href="/security">Security Office</a>
        <a href="/reports">Reports</a>
        <form action="/logout" method="post" style="display:inline;">
          <button type="submit" style="padding: 0.5rem 1rem; background: #dc2626; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 500;">Logout</button>
        </form>
      </div>
    </nav>
  </header>

  <main class="admin-main">
    <div class="welcome-section">
      <h2>Welcome back, <%= currentUser.name %>!</h2>
      <p>Here's an overview of the Lost & Found system performance and recent activities.</p>
    </div>

    <div class="stats-grid">
      <div class="stat-card users">
        <div class="icon">👥</div>
        <h3>Total Users</h3>
        <p class="number"><%= metrics.users %></p>
      </div>
      <div class="stat-card items">
        <div class="icon">📦</div>
        <h3>Total Items</h3>
        <p class="number"><%= metrics.items %></p>
      </div>
      <div class="stat-card claims">
        <div class="icon">📋</div>
        <h3>Pending Claims</h3>
        <p class="number"><%= metrics.claims %></p>
      </div>
      <div class="stat-card found">
        <div class="icon">✅</div>
        <h3>Found Items</h3>
        <p class="number"><%= metrics.found %></p>
      </div>
      <div class="stat-card lost">
        <div class="icon">❌</div>
        <h3>Lost Items</h3>
        <p class="number"><%= metrics.lost %></p>
      </div>
    </div>

    <div class="dashboard-grid">
      <div class="recent-activity">
        <h3>📊 Recent Activity</h3>
        <div class="activity-list">
          <% items.slice(0, 5).forEach(item => { %>
            <div class="activity-item">
              <div class="activity-icon report">
                <% if (item.type === 'found') { %>✅<% } else { %>❌<% } %>
              </div>
              <div class="activity-content">
                <p class="title"><%= item.title %></p>
                <p class="meta"><%= item.type %> • <%= item.reporter %> • <%= new Date(item.updated_at).toLocaleDateString() %></p>
              </div>
            </div>
          <% }) %>
          <% if (items.length === 0) { %>
            <p style="text-align: center; color: #666; padding: 2rem;">No recent activity</p>
          <% } %>
        </div>
      </div>

      <div class="quick-actions">
        <h3>⚡ Quick Actions</h3>
        <div class="action-buttons">
          <a href="/security" class="action-btn">
            <span class="icon">🛡️</span>
            <span>Manage Security Office</span>
          </a>
          <a href="/reports" class="action-btn">
            <span class="icon">📊</span>
            <span>View Detailed Reports</span>
          </a>
          <a href="/user" class="action-btn">
            <span class="icon">👤</span>
            <span>Access User Portal</span>
          </a>
        </div>
      </div>
    </div>

    <div class="data-tables">
      <h3>📋 Recent Items & Claims</h3>

      <div class="table-container">
        <h4 style="color: #1f4d8d; margin-bottom: 1rem;">Recent Items</h4>
        <table class="data-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Type</th>
              <th>Status</th>
              <th>Reporter</th>
              <th>Last Updated</th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach(item => { %>
              <tr>
                <td><%= item.title %></td>
                <td><%= item.type %></td>
                <td><span class="status-badge status-<%= item.status %>"><%= item.status.replace(/_/g, ' ') %></span></td>
                <td><%= item.reporter %></td>
                <td><%= new Date(item.updated_at).toLocaleString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="table-container">
        <h4 style="color: #1f4d8d; margin-bottom: 1rem;">Recent Claim Requests</h4>
        <table class="data-table">
          <thead>
            <tr>
              <th>Item</th>
              <th>Claimant</th>
              <th>Status</th>
              <th>Requested</th>
            </tr>
          </thead>
          <tbody>
            <% claims.forEach(claim => { %>
              <tr>
                <td><%= claim.item_title %></td>
                <td><%= claim.claimant %></td>
                <td><span class="status-badge status-<%= claim.status %>"><%= claim.status %></span></td>
                <td><%= new Date(claim.requested_at).toLocaleString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</body>
</html>
